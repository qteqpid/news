{
  "name": "zhihu",
  "order": 20,
  "description": "Daily Zhihu hot-topic signals.",
  "outputs": [
    {
      "path": "{root}/zhihu/{date}.json",
      "type": "json_array",
      "min_items": 1,
      "allowed_keys": ["title", "link", "summary", "published", "dedupe_id"]
    }
  ],
  "steps": [
    {
      "name": "fetch",
      "type": "command",
      "command": ["python3", "{root}/fetch_zhihu.py", "--date", "{date}"]
    }
  ]
}
